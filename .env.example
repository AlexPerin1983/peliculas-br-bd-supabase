# Frontend
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_VAPID_PUBLIC_KEY=your_web_push_public_key_here

# Edge Functions / server-side secrets
RESEND_API_KEY=your_resend_api_key_here
ABACATE_API_KEY=your_abacatepay_api_key_here
ABACATE_WEBHOOK_SECRET=your_abacatepay_webhook_secret_here
ABACATE_WEBHOOK_PUBLIC_KEY=your_abacatepay_public_hmac_key_here
VAPID_PUBLIC_KEY=your_web_push_public_key_here
VAPID_PRIVATE_KEY=your_web_push_private_key_here
VAPID_SUBJECT=mailto:suporte@your-domain.com
AGENDA_PUSH_CRON_SECRET=generate_a_random_secret
# Meta Conversions API (CAPI) - token do System User (Events Manager)
# Setar com: supabase secrets set META_CAPI_TOKEN=...  (nunca commitar o valor)
META_CAPI_TOKEN=your_meta_capi_system_user_token_here

# Adicione outras variaveis de ambiente aqui conforme necessario
